# Copy to ".env" and fill in. NEVER commit your real .env (it's git-ignored).

ANTHROPIC_API_KEY=
# Model the proxy uses (server-owned, so the client can't change it).
ANTHROPIC_MODEL=claude-sonnet-4-6
MAX_TOKENS_CAP=1500

# Database — same code works on both:
#   local:  sqlite:///./jobhub.db
#   hosted: postgresql://user:password@host:5432/dbname   <-- accessible anywhere
DATABASE_URL=sqlite:///./jobhub.db

# CORS — only needed if the frontend is served from a DIFFERENT origin than the API.
# When the backend serves the built frontend (production), leave as * or set your domain.
ALLOWED_ORIGINS=*

# Set to the built frontend folder to serve the app from this backend (production).
# e.g. STATIC_DIR=../frontend/dist  (Docker sets this automatically)
STATIC_DIR=

# Shared password to access the app. STRONGLY recommended before deploying
# publicly — without it, anyone with the URL can use your Anthropic key.
# Leave empty for no login (e.g. local-only use).
APP_PASSWORD=
